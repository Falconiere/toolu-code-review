{
  "name": "toolu-code-review",
  "version": "2.4.0",
  "private": true,
  "description": "Toolu AI Code Review — GitHub JS action (TypeScript, OpenRouter + Vercel AI SDK)",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint --type-aware --deny-warnings",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "cd \"$(git rev-parse --show-toplevel)\" && lefthook install",
    "check": "bun run typecheck && bun run lint && bun run fmt:check && bun run test"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@ai-sdk/deepseek": "0.2.16",
    "@octokit/auth-app": "^7.1.5",
    "@openrouter/ai-sdk-provider": "^0.7.0",
    "ai": "^4.3.0",
    "jsonrepair": "^3.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.2",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
