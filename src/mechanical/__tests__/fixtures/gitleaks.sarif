{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "semanticVersion": "v8.0.0",
          "informationUri": "https://github.com/gitleaks/gitleaks",
          "rules": [
            {
              "id": "github-pat",
              "shortDescription": {
                "text": "Uncovered a GitHub Personal Access Token, potentially leading to unauthorized repository access and sensitive content exposure."
              }
            },
            {
              "id": "gitlab-pat",
              "shortDescription": {
                "text": "Identified a GitLab Personal Access Token, risking unauthorized access to GitLab repositories and codebase exposure."
              }
            }
          ]
        }
      },
      "results": [
        {
          "message": {
            "text": "gitlab-pat has detected secret for file leak.ts."
          },
          "ruleId": "gitlab-pat",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "leak.ts"
                },
                "region": {
                  "startLine": 2,
                  "startColumn": 25,
                  "endLine": 2,
                  "endColumn": 50,
                  "snippet": {
                    "text": "REDACTED-GITLAB-PAT"
                  }
                }
              }
            }
          ],
          "partialFingerprints": {
            "commitSha": "",
            "email": "",
            "author": "",
            "date": "",
            "commitMessage": ""
          },
          "properties": {
            "tags": []
          }
        },
        {
          "message": {
            "text": "github-pat has detected secret for file leak.ts."
          },
          "ruleId": "github-pat",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "leak.ts"
                },
                "region": {
                  "startLine": 1,
                  "startColumn": 23,
                  "endLine": 1,
                  "endColumn": 62,
                  "snippet": {
                    "text": "REDACTED-GITHUB-PAT"
                  }
                }
              }
            }
          ],
          "partialFingerprints": {
            "commitSha": "",
            "email": "",
            "author": "",
            "date": "",
            "commitMessage": ""
          },
          "properties": {
            "tags": []
          }
        }
      ]
    }
  ]
}
